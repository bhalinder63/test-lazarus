{% doc %}
  Tab Item Block

  Defines a single tab for the tabbed product grid section.
  Stores a collection reference and display label.

  @param {object} block - The block object with settings
  @example {% content_for 'block', type: 'tab-item', id: 'tab-1' %}
{% enddoc %}

{%- comment -%}
  This block is a data-only block. It does not render visible HTML on its own.
  The parent section (tabbed-product-grid) reads block.settings to build
  tab buttons and product panels.
{%- endcomment -%}

{% schema %}
{
  "name": "t:names.tab_item",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "Tab"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    }
  ],
  "presets": [
    {
      "name": "t:names.tab_item"
    }
  ]
}
{% endschema %}
